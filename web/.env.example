# YardScore web environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.

# API base URL used by all frontend fetch calls.
# Default (single-machine dev): http://localhost:8000
# LAN testing (iPhone / other devices on same Wi-Fi):
#   NEXT_PUBLIC_API_URL=http://192.168.1.42:8000   ← your Mac's LAN IP
# Homelab / mDNS hostname:
#   NEXT_PUBLIC_API_URL=http://yardscore.local:8000
#   NEXT_PUBLIC_API_URL=http://yardscore.drewhenry.lan:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
